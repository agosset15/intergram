TELEGRAM_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

META_PARAMS=plan,email,tgid,source,username

# Mount entire app under a sub-path (empty = serve from /)
# Example: BASE_PATH=/support → widget at /support/js/widget.js, hook at /support/hook
BASE_PATH=

# Redis url (optional — falls back to in-memory sessions if absent/unreachable)
# docker-compose sets this automatically; set manually for standalone deploys
REDIS_URL=redis://localhost:6379
PORT=3000
