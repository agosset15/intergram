TELEGRAM_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

META_PARAMS=uid,plan,email,source,username

# Redis url (optional — falls back to in-memory sessions if absent/unreachable)
# docker-compose sets this automatically; set manually for standalone deploys
REDIS_URL=redis://localhost:6379

# External user directory base url (optional)
# GET {API_BASE}/users?uid=|username= -> { "id": ... }
# GET {API_BASE}/users/<id>/summary   -> plain text appended to the card
API_BASE=
PORT=3000
